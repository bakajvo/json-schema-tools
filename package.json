    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.32.2",
    "husky": "^8.0.3",
    "lerna": "^6.0.1",
    "lint-staged": "^13.1.2",
    "prettier": "2.8.4",
    "typescript": "^4.9.5"
